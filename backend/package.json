    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "discord-interactions": "^4.4.0",
    "discord.js": "^14.25.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jimp": "^0.16.1",
    "mercadopago": "^2.12.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
