{
  "name": "vematize-bot-service",
  "version": "1.0.0",
  "description": "Serviço de bots de vendas multi-tenant (Discord, Telegram) - Vematize",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "dev:ts-node": "ts-node src/server.ts",
    "dev:tsx": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "bot",
    "discord",
    "telegram",
    "sales",
    "multi-tenant"
  ],
  "author": "Vematize",
  "license": "MIT",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@types/jsonwebtoken": "^9.0.10",
    "cors": "^2.8.5",
    "discord-interactions": "^4.4.0",
    "discord.js": "^14.25.1",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "fluent-ffmpeg": "^2.1.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.11.0",
    "mongodb": "^6.17.0",
    "multer": "^2.0.2",
    "next": "^14.2.24",
    "node-cron": "^4.2.1",
    "otplib": "^12.0.1",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "qrcode": "^1.5.4",
    "sdk-node-apis-efi": "^1.2.25",
    "sharp": "^0.34.5",
    "stripe": "^19.3.1",
    "telegraf": "^4.16.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.0.0",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
